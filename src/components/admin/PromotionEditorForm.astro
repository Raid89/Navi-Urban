---
import type { PromotionItem } from '../../types/catalog';

interface Props {
  promotion?: PromotionItem | null;
  title: string;
  subtitle: string;
  submitLabel: string;
  cancelHref: string;
}

const { promotion = null, title, subtitle, submitLabel, cancelHref } = Astro.props;
---

<article class="editor-card">
  <div class="editor-head">
    <div>
      <p class="eyebrow">{subtitle}</p>
      <h1>{title}</h1>
    </div>
    <a class="btn btn-ghost" href={cancelHref}>Volver</a>
  </div>

  <form method="post" action="/api/admin/promotions" class="editor-form" id="promotionForm">
    <input type="hidden" name="id" value={promotion?.id || ''} />

    <label>
      Titulo
      <input name="title" value={promotion?.title || ''} placeholder="Running Essentials -25%" required />
    </label>

    <label>
      Descripcion
      <textarea name="description" rows="4" required>{promotion?.description || ''}</textarea>
    </label>

    <label>
      Redireccion
      <input name="redirect" value={promotion?.redirect || ''} placeholder="#catalogo" required />
    </label>

    <button class="btn btn-main" type="submit" id="promotionSubmitButton" data-default-label={submitLabel}>{submitLabel}</button>
  </form>
</article>

<script>
  const promotionForm = document.getElementById('promotionForm');
  const promotionSubmitButton = document.getElementById('promotionSubmitButton');
  let isSubmittingPromotion = false;

  promotionForm?.addEventListener('submit', () => {
    if (isSubmittingPromotion) return;
    isSubmittingPromotion = true;

    if (!(promotionSubmitButton instanceof HTMLButtonElement)) return;
    const defaultLabel = promotionSubmitButton.dataset.defaultLabel || promotionSubmitButton.textContent || '';

    if (!promotionSubmitButton.dataset.defaultLabel) {
      promotionSubmitButton.dataset.defaultLabel = defaultLabel;
    }

    promotionSubmitButton.disabled = true;
    promotionSubmitButton.setAttribute('aria-busy', 'true');
    promotionSubmitButton.textContent = 'Guardando...';
  });
</script>

<style>
  .editor-card {
    background: var(--card);
    border: 1px solid var(--line);
    border-radius: 18px;
    padding: 1rem;
    box-shadow: 0 18px 40px rgba(17, 17, 17, 0.07);
  }

  .editor-head {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1rem;
  }

  .eyebrow {
    margin: 0 0 0.35rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    font-size: 0.75rem;
    color: var(--brand);
    font-weight: 800;
  }

  .editor-head h1 {
    margin: 0;
    font-size: clamp(1.4rem, 2.6vw, 2rem);
  }

  .editor-form {
    display: grid;
    gap: 0.85rem;
  }

  .editor-form label {
    display: grid;
    gap: 0.45rem;
    font-weight: 700;
  }

  .editor-form input,
  .editor-form textarea {
    width: 100%;
    font: inherit;
    border: 1px solid #cdc6b8;
    background: #fff;
    border-radius: 10px;
    padding: 0.65rem 0.75rem;
  }

  .editor-form textarea {
    resize: vertical;
  }

  @media (max-width: 900px) {
    .editor-head {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>
