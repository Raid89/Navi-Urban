---
import type { ProductItem } from '../../types/catalog';

interface Props {
  product?: ProductItem | null;
  title: string;
  subtitle: string;
  submitLabel: string;
  cancelHref: string;
}

const { product = null, title, subtitle, submitLabel, cancelHref } = Astro.props;

const initialImages = JSON.stringify(product?.images ?? []);
const initialSizes = JSON.stringify(product?.sizes ?? []);
const normalizeHex = (value: string) => {
  const normalized = String(value || '').trim();
  const expanded = normalized.startsWith('#') ? normalized : `#${normalized}`;
  return /^#[0-9a-fA-F]{6}$/.test(expanded) ? expanded.toLowerCase() : '#bdbdbd';
};

const colorMap = new Map<string, { name: string; hex: string }>();

(product?.colors ?? []).forEach((color) => {
  if (typeof color === 'string') {
    const name = String(color || '').trim();
    if (!name) return;
    colorMap.set(name.toLowerCase(), { name, hex: '#bdbdbd' });
    return;
  }

  const name = String(color.name || '').trim();
  if (!name) return;
  colorMap.set(name.toLowerCase(), { name, hex: normalizeHex(color.hex) });
});

(product?.images ?? []).forEach((image) => {
  const name = typeof image === 'string' ? '' : String(image.color || '').trim();
  if (!name) return;
  const key = name.toLowerCase();
  if (!colorMap.has(key)) {
    colorMap.set(key, { name, hex: '#bdbdbd' });
  }
});

const initialColors = JSON.stringify([...colorMap.values()]);
---

<article class="editor-card">
  <div class="editor-head">
    <div>
      <p class="eyebrow">{subtitle}</p>
      <h1>{title}</h1>
    </div>
    <a class="btn btn-ghost" href={cancelHref}>Volver</a>
  </div>

  <form id="productForm" method="post" action="/api/admin/products" class="editor-form">
    <input type="hidden" name="id" value={product?.id || ''} />
    <input type="hidden" id="productImagesJson" name="imagesJson" value={initialImages} />
    <input type="hidden" id="colorsJson" name="colorsJson" value={initialColors} />
    <input type="hidden" id="sizesJson" name="sizesJson" value={initialSizes} />

    <label>
      Nombre del producto
      <input name="name" value={product?.name || ''} placeholder="NAVI Sprint 01" required />
    </label>

    <div class="two-cols">
      <label>
        Categoria
        <input name="category" value={product?.category || ''} placeholder="Running" required />
      </label>
      <label>
        Tag
        <input name="tag" value={product?.tag || ''} placeholder="Nuevo" required />
      </label>
    </div>

    <label>
      Descripcion
      <textarea name="description" rows="4" required>{product?.description || ''}</textarea>
    </label>

    <div class="two-cols">
      <label>
        Precio
        <input name="price" type="number" min="0" step="1" value={product?.price || 0} required />
      </label>
      <div class="switches">
        <label class="switch"><input name="isPromotion" type="checkbox" checked={product?.isPromotion} /> En promocion</label>
        <label class="switch"><input name="visible" type="checkbox" checked={product?.visible ?? true} /> Visible</label>
      </div>
    </div>

    <section class="subsection">
      <div class="subsection-head">
        <h2>Tallas</h2>
        <p>Gestiona disponibilidad sin escribir JSON.</p>
      </div>
      <div id="sizesBoard" class="sizes-board"></div>
      <div class="size-adder">
        <input id="newSizeInput" placeholder="Nueva talla (ej. 28)" />
        <button type="button" class="btn btn-ghost" id="addSizeButton">Agregar talla</button>
      </div>
    </section>

    <section class="subsection">
      <div class="subsection-head">
        <h2>Colores</h2>
        <p>Define los colores disponibles del modelo y luego asignalos a cada imagen.</p>
      </div>
      <div id="colorsBoard" class="colors-board"></div>
      <div class="color-adder">
        <input id="newColorInput" placeholder="Nombre (ej. Blanco)" />
        <input id="newColorHexInput" type="color" value="#bdbdbd" aria-label="Seleccionar color" />
        <button type="button" class="btn btn-ghost" id="addColorButton">Agregar color</button>
      </div>
    </section>

    <section class="subsection">
      <div class="subsection-head">
        <h2>Imagenes</h2>
        <p>Sube imagenes a Cloudinary, revisa la previsualizacion y asigna un color por imagen.</p>
      </div>
      <div class="upload-actions">
        <input id="productImageInput" type="file" accept="image/*" multiple />
        <button class="btn btn-ghost" type="button" id="uploadProductImages">Subir imagenes</button>
      </div>
      <p id="uploadStatus" class="request-status" aria-live="polite"></p>
      <div id="productImagesPreview" class="image-preview-grid"></div>
    </section>

    <button class="btn btn-main" type="submit" id="productSubmitButton" data-default-label={submitLabel}>{submitLabel}</button>
  </form>
</article>

<script>
  type ProductImageEntry = {
    url: string;
    publicId: string;
    color?: string;
  };

  type ProductSizeEntry = {
    size: string;
    available: boolean;
  };

  type ProductColorEntry = {
    name: string;
    hex: string;
  };

  const productForm = document.getElementById('productForm') as HTMLFormElement | null;
  const uploadButton = document.getElementById('uploadProductImages') as HTMLButtonElement | null;
  const productImageInput = document.getElementById('productImageInput') as HTMLInputElement | null;
  const productImagesJson = document.getElementById('productImagesJson') as HTMLInputElement | null;
  const productImagesPreview = document.getElementById('productImagesPreview') as HTMLElement | null;
  const colorsJsonInput = document.getElementById('colorsJson') as HTMLInputElement | null;
  const colorsBoard = document.getElementById('colorsBoard') as HTMLElement | null;
  const newColorInput = document.getElementById('newColorInput') as HTMLInputElement | null;
  const newColorHexInput = document.getElementById('newColorHexInput') as HTMLInputElement | null;
  const addColorButton = document.getElementById('addColorButton') as HTMLButtonElement | null;
  const sizesJsonInput = document.getElementById('sizesJson') as HTMLInputElement | null;
  const sizesBoard = document.getElementById('sizesBoard') as HTMLElement | null;
  const newSizeInput = document.getElementById('newSizeInput') as HTMLInputElement | null;
  const addSizeButton = document.getElementById('addSizeButton') as HTMLButtonElement | null;
  const uploadStatus = document.getElementById('uploadStatus') as HTMLElement | null;
  const submitButton = document.getElementById('productSubmitButton') as HTMLButtonElement | null;
  let isSubmitting = false;

  const setButtonBusy = (button: HTMLButtonElement | null, isBusy: boolean, busyLabel: string) => {
    if (!(button instanceof HTMLButtonElement)) return;
    const defaultLabel = button.dataset.defaultLabel || button.textContent || '';

    if (!button.dataset.defaultLabel) {
      button.dataset.defaultLabel = defaultLabel;
    }

    button.disabled = isBusy;
    button.setAttribute('aria-busy', String(isBusy));
    button.textContent = isBusy ? busyLabel : (button.dataset.defaultLabel || defaultLabel);
  };

  const setUploadStatus = (text = '') => {
    if (!(uploadStatus instanceof HTMLElement)) return;
    uploadStatus.textContent = text;
  };

  const escapeHtml = (value: string | number | null | undefined) =>
    String(value ?? '').replace(/[&<>'"]/g, (character) => {
      switch (character) {
        case '&':
          return '&amp;';
        case '<':
          return '&lt;';
        case '>':
          return '&gt;';
        case '"':
          return '&quot;';
        case "'":
          return '&#39;';
        default:
          return character;
      }
    });

  const parseImages = (): ProductImageEntry[] => {
    try {
      return JSON.parse(productImagesJson?.value || '[]') as ProductImageEntry[];
    } catch {
      return [];
    }
  };

  const parseColors = (): ProductColorEntry[] => {
    try {
      const parsed = JSON.parse(colorsJsonInput?.value || '[]') as Array<ProductColorEntry | string>;
      return parsed
        .map((item) => {
          if (typeof item === 'string') {
            const name = String(item || '').trim();
            return name ? { name, hex: '#bdbdbd' } : null;
          }

          const name = String(item?.name || '').trim();
          if (!name) return null;

          const normalizedHex = String(item?.hex || '').trim();
          const hex = /^#[0-9a-fA-F]{6}$/.test(normalizedHex) ? normalizedHex.toLowerCase() : '#bdbdbd';
          return { name, hex };
        })
        .filter((item): item is ProductColorEntry => Boolean(item));
    } catch {
      return [];
    }
  };

  const parseSizes = (): ProductSizeEntry[] => {
    try {
      return JSON.parse(sizesJsonInput?.value || '[]') as ProductSizeEntry[];
    } catch {
      return [];
    }
  };

  const saveSizes = (sizes: ProductSizeEntry[]) => {
    if (sizesJsonInput) {
      sizesJsonInput.value = JSON.stringify(sizes);
    }
  };

  const saveColors = (colors: ProductColorEntry[]) => {
    if (colorsJsonInput) {
      colorsJsonInput.value = JSON.stringify(colors);
    }
  };

  const saveImages = (images: Array<ProductImageEntry | string>) => {
    if (productImagesJson) {
      productImagesJson.value = JSON.stringify(images);
    }
  };

  const getImageUrl = (image: ProductImageEntry | string | undefined) => (image && typeof image === 'object' ? image.url || '' : String(image || ''));

  const getImageColor = (image: ProductImageEntry | string | undefined) => (image && typeof image === 'object' ? String(image.color || '').trim() : '');

  const normalizeColorKey = (value: string | undefined) => String(value || '').trim().toLowerCase();

  const normalizeColorHex = (value: string | undefined) => {
    const normalized = String(value || '').trim();
    const expanded = normalized.startsWith('#') ? normalized : `#${normalized}`;
    return /^#[0-9a-fA-F]{6}$/.test(expanded) ? expanded.toLowerCase() : '#bdbdbd';
  };

  const getUniqueColors = (values: ProductColorEntry[]) => {
    const map = new Map<string, ProductColorEntry>();

    values.forEach((entry) => {
      const name = String(entry?.name || '').trim();
      if (!name) return;
      map.set(normalizeColorKey(name), { name, hex: normalizeColorHex(entry.hex) });
    });

    return [...map.values()];
  };

  const renderSizes = () => {
    if (!sizesBoard) return;
    const sizes = parseSizes();

    if (!sizes.length) {
      sizesBoard.innerHTML = '<p class="empty-note">Aun no hay tallas. Agrega una para comenzar.</p>';
      return;
    }

    sizesBoard.innerHTML = sizes
      .map(
        (sizeOption: ProductSizeEntry, index: number) => `
          <article class="size-card ${sizeOption.available ? 'available' : 'unavailable'}" data-size-index="${index}">
            <div class="size-card-main">
              <strong>Talla ${sizeOption.size}</strong>
              <span>${sizeOption.available ? 'Disponible' : 'Agotada'}</span>
            </div>
            <div class="size-card-actions">
              <button type="button" class="size-toggle">${sizeOption.available ? 'Marcar agotada' : 'Marcar disponible'}</button>
              <button type="button" class="size-remove" data-remove-size="${index}">Eliminar</button>
            </div>
          </article>
        `
      )
      .join('');

    sizesBoard.querySelectorAll('.size-toggle').forEach((button) => {
      button.addEventListener('click', () => {
        const parent = button.closest('[data-size-index]');
        const index = Number(parent?.getAttribute('data-size-index'));
        const current = parseSizes();
        if (Number.isNaN(index) || !current[index]) return;
        current[index].available = !current[index].available;
        saveSizes(current);
        renderSizes();
      });
    });

    sizesBoard.querySelectorAll('[data-remove-size]').forEach((button) => {
      button.addEventListener('click', () => {
        const index = Number(button.getAttribute('data-remove-size'));
        const current = parseSizes();
        if (Number.isNaN(index)) return;
        current.splice(index, 1);
        saveSizes(current);
        renderSizes();
      });
    });
  };

  const renderColors = () => {
    if (!colorsBoard) return;
    const colors = parseColors();

    if (!colors.length) {
      colorsBoard.innerHTML = '<p class="empty-note">Agrega colores para poder asignarlos a las imagenes.</p>';
      return;
    }

    colorsBoard.innerHTML = colors
      .map(
        (color: ProductColorEntry, index: number) => `
          <article class="color-card" data-color-index="${index}">
            <div class="color-card-main">
              <label class="color-name-field">
                <span>Nombre</span>
                <input type="text" value="${escapeHtml(color.name)}" data-color-name-index="${index}" />
              </label>
              <label class="color-hex-field">
                <span>Tono</span>
                <input type="color" value="${escapeHtml(normalizeColorHex(color.hex))}" data-color-hex-index="${index}" />
              </label>
            </div>
            <div class="color-card-actions">
              <button type="button" class="color-remove" data-remove-color="${index}">Eliminar</button>
            </div>
          </article>
        `
      )
      .join('');

    colorsBoard.querySelectorAll('[data-remove-color]').forEach((button) => {
      button.addEventListener('click', () => {
        const index = Number(button.getAttribute('data-remove-color'));
        const currentColors = parseColors();
        if (Number.isNaN(index) || !currentColors[index]) return;

        const removedColor = String(currentColors[index]?.name || '').trim();
        currentColors.splice(index, 1);
        saveColors(getUniqueColors(currentColors));

        const updatedImages = parseImages().map((image: ProductImageEntry | string) => {
          if (typeof image === 'string') return image;
          if (normalizeColorKey(image.color) !== normalizeColorKey(removedColor)) {
            return image;
          }

          return { ...image, color: '' };
        });

        saveImages(updatedImages);
        renderColors();
        renderImages();
      });
    });

    colorsBoard.querySelectorAll<HTMLInputElement>('[data-color-name-index]').forEach((input) => {
      input.addEventListener('change', () => {
        const index = Number(input.getAttribute('data-color-name-index'));
        const currentColors = parseColors();
        if (Number.isNaN(index) || !currentColors[index]) return;

        const previousName = currentColors[index].name;
        const nextName = String(input.value || '').trim();
        if (!nextName) {
          alert('El nombre del color es obligatorio');
          renderColors();
          return;
        }

        const duplicated = currentColors.some((color, colorIndex) => colorIndex !== index && normalizeColorKey(color.name) === normalizeColorKey(nextName));
        if (duplicated) {
          alert('Ese color ya existe');
          renderColors();
          return;
        }

        currentColors[index] = { ...currentColors[index], name: nextName };
        saveColors(getUniqueColors(currentColors));

        const updatedImages = parseImages().map((image: ProductImageEntry | string) => {
          if (typeof image === 'string') return image;
          if (normalizeColorKey(image.color) !== normalizeColorKey(previousName)) {
            return image;
          }

          return { ...image, color: nextName };
        });

        saveImages(updatedImages);
        renderColors();
        renderImages();
      });
    });

    colorsBoard.querySelectorAll<HTMLInputElement>('[data-color-hex-index]').forEach((input) => {
      input.addEventListener('change', () => {
        const index = Number(input.getAttribute('data-color-hex-index'));
        const currentColors = parseColors();
        if (Number.isNaN(index) || !currentColors[index]) return;

        currentColors[index] = { ...currentColors[index], hex: normalizeColorHex(input.value) };
        saveColors(getUniqueColors(currentColors));
        renderColors();
      });
    });
  };

  const renderImages = () => {
    const images = parseImages();
    const colors = parseColors();
    if (!productImagesPreview) return;

    if (!images.length) {
      productImagesPreview.innerHTML = '<p class="empty-note">Sube imagenes para ver la previsualizacion.</p>';
      return;
    }

    const mainImage = getImageUrl(images[0]);
    const thumbs = images
      .map(
        (image: ProductImageEntry | string, index: number) => `
          <article class="preview-item" data-image-index="${index}">
            <div class="preview-thumb-wrap">
              <img src="${escapeHtml(getImageUrl(image))}" alt="Imagen ${index + 1}" />
              <span class="preview-badge">#${index + 1}</span>
            </div>
            ${
              colors.length
                ? `
                  <label class="preview-color-field">
                    <span>Color</span>
                    <select class="preview-color-select" data-image-color-index="${index}">
                      <option value="">Sin color</option>
                      ${getUniqueColors(colors)
                        .map(
                          (color) => `
                            <option value="${escapeHtml(color.name)}" ${normalizeColorKey(color.name) === normalizeColorKey(getImageColor(image)) ? 'selected' : ''}>
                              ${escapeHtml(color.name)}
                            </option>
                          `
                        )
                        .join('')}
                    </select>
                  </label>
                `
                : '<p class="preview-color-empty">Agrega colores para asignar variantes.</p>'
            }
            <button type="button" class="preview-remove" data-remove-image="${index}">Quitar</button>
          </article>
        `
      )
      .join('');

    productImagesPreview.innerHTML = `
      <article class="preview-main">
        <img src="${mainImage}" alt="Imagen principal" />
        <p>Imagen principal</p>
      </article>
      <div class="preview-thumbs-grid">${thumbs}</div>
    `;

    productImagesPreview.querySelectorAll('[data-remove-image]').forEach((button) => {
      button.addEventListener('click', () => {
        const index = Number(button.getAttribute('data-remove-image'));
        const current = parseImages();
        if (Number.isNaN(index)) return;
        current.splice(index, 1);
        saveImages(current);
        renderImages();
      });
    });

    productImagesPreview.querySelectorAll<HTMLSelectElement>('[data-image-color-index]').forEach((select) => {
      select.addEventListener('change', () => {
        const index = Number(select.getAttribute('data-image-color-index'));
        const current = parseImages();
        if (Number.isNaN(index) || !current[index]) return;

        const nextColor = String(select.value || '').trim();
        if (typeof current[index] === 'string') {
          current[index] = { url: current[index], publicId: '', color: nextColor };
        } else {
          current[index] = { ...current[index], color: nextColor };
        }

        saveImages(current);
        renderImages();
      });
    });
  };

  const uploadImages = async () => {
    const files = Array.from(productImageInput?.files || []);
    if (!files.length) return;

    for (const file of files) {
      const formData = new FormData();
      formData.append('file', file);

      const response = await fetch('/api/admin/upload-image', {
        method: 'POST',
        body: formData
      });

      if (!response.ok) {
        throw new Error('Error al subir una imagen');
      }

      const image = await response.json();
      const current = parseImages();
      current.push({ ...image, color: '' } as ProductImageEntry);
      saveImages(current);
    }

    if (productImageInput) productImageInput.value = '';
    renderImages();
  };

  uploadButton?.addEventListener('click', async () => {
    if (!(uploadButton instanceof HTMLButtonElement)) return;

    try {
      setButtonBusy(uploadButton, true, 'Subiendo...');
      setUploadStatus('Subiendo imagenes...');
      await uploadImages();
      setUploadStatus('Imagenes subidas correctamente.');
    } catch (error) {
      alert(error instanceof Error ? error.message : 'No se pudo subir la imagen');
      setUploadStatus('No se pudieron subir las imagenes.');
    } finally {
      setButtonBusy(uploadButton, false, 'Subiendo...');
    }
  });

  addSizeButton?.addEventListener('click', () => {
    const sizeValue = String(newSizeInput?.value || '').trim();
    if (!sizeValue) return;

    const current = parseSizes();
    if (current.some((item: ProductSizeEntry) => String(item.size) === sizeValue)) {
      alert('Esa talla ya existe');
      return;
    }

    current.push({ size: sizeValue, available: true });
    saveSizes(current);
    if (newSizeInput) newSizeInput.value = '';
    renderSizes();
  });

  addColorButton?.addEventListener('click', () => {
    const colorName = String(newColorInput?.value || '').trim();
    if (!colorName) return;

    const colorHex = normalizeColorHex(String(newColorHexInput?.value || '#bdbdbd'));

    const current = parseColors();
    if (current.some((value: ProductColorEntry) => normalizeColorKey(value.name) === normalizeColorKey(colorName))) {
      alert('Ese color ya existe');
      return;
    }

    current.push({ name: colorName, hex: colorHex });
    saveColors(getUniqueColors(current));
    if (newColorInput) newColorInput.value = '';
    if (newColorHexInput) newColorHexInput.value = '#bdbdbd';
    renderColors();
    renderImages();
  });

  productForm?.addEventListener('submit', () => {
    if (isSubmitting) return;
    isSubmitting = true;

    if (productImagesJson) {
      productImagesJson.value = JSON.stringify(parseImages());
    }
    if (sizesJsonInput) {
      sizesJsonInput.value = JSON.stringify(parseSizes());
    }
    if (colorsJsonInput) {
      colorsJsonInput.value = JSON.stringify(getUniqueColors(parseColors()));
    }

    setButtonBusy(submitButton, true, 'Guardando...');
  });

  renderColors();
  renderSizes();
  renderImages();
</script>

<style>
  .editor-card {
    background: var(--card);
    border: 1px solid var(--line);
    border-radius: 18px;
    padding: 1rem;
    box-shadow: 0 18px 40px rgba(17, 17, 17, 0.07);
    overflow: hidden;
  }

  .editor-head {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1rem;
  }

  .eyebrow {
    margin: 0 0 0.35rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    font-size: 0.75rem;
    color: var(--brand);
    font-weight: 800;
  }

  .editor-head h1 {
    margin: 0;
    font-size: clamp(1.4rem, 2.6vw, 2rem);
  }

  .editor-form {
    display: grid;
    gap: 0.9rem;
    min-width: 0;
  }

  .editor-form label {
    display: grid;
    gap: 0.45rem;
    font-weight: 700;
  }

  .editor-form input,
  .editor-form textarea {
    width: 100%;
    max-width: 100%;
    font: inherit;
    border: 1px solid #cdc6b8;
    background: #fff;
    border-radius: 10px;
    padding: 0.65rem 0.75rem;
  }

  .editor-form input[type='file'] {
    min-width: 0;
  }

  .editor-form textarea {
    resize: vertical;
  }

  .two-cols {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.75rem;
  }

  .switches {
    display: grid;
    gap: 0.45rem;
    align-content: center;
  }

  .switch {
    display: flex;
    align-items: center;
    gap: 0.45rem;
    font-weight: 600;
  }

  .subsection {
    border: 1px solid var(--line);
    border-radius: 14px;
    background: var(--bg-soft);
    padding: 0.85rem;
    display: grid;
    gap: 0.7rem;
  }

  .subsection-head h2 {
    margin: 0;
    font-size: 1rem;
  }

  .subsection-head p {
    margin: 0.2rem 0 0;
    color: var(--muted);
    font-size: 0.88rem;
  }

  .colors-board {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 0.55rem;
  }

  .color-card {
    display: grid;
    gap: 0.5rem;
    border-radius: 14px;
    border: 1px solid var(--line);
    padding: 0.6rem;
    background: #fff;
  }

  .color-card-main {
    display: grid;
    gap: 0.45rem;
  }

  .color-name-field,
  .color-hex-field {
    display: grid;
    gap: 0.25rem;
  }

  .color-name-field span,
  .color-hex-field span {
    font-size: 0.74rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--muted);
  }

  .color-name-field input {
    width: 100%;
  }

  .color-hex-field input {
    width: 56px;
    height: 34px;
    padding: 0.2rem;
    border-radius: 8px;
    border: 1px solid #d8d1c4;
    cursor: pointer;
  }

  .color-card-actions {
    display: flex;
    gap: 0.45rem;
    flex-wrap: wrap;
  }

  .color-remove {
    border: 1px solid transparent;
    border-radius: 999px;
    cursor: pointer;
    padding: 0.28rem 0.5rem;
    font: inherit;
