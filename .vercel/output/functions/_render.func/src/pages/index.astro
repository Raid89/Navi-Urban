---
import BaseLayout from '../components/layout/BaseLayout.astro';
import Navbar from '../components/sections/Navbar.astro';
import HeroSection from '../components/sections/HeroSection.astro';
import PromotionsSection from '../components/sections/PromotionsSection.astro';
import CatalogSection from '../components/sections/CatalogSection.astro';
import SiteFooter from '../components/sections/SiteFooter.astro';
import { getPromotions, getVisibleProducts } from '../lib/catalog';

const [promotions, products] = await Promise.all([getPromotions(), getVisibleProducts()]);
---

<BaseLayout
  title="NAVI URBAN | Zapatos Urbanos"
  description="NAVI URBAN: landing oficial de zapatos urbanos y deportivos con promociones y catalogo interactivo."
>
  <Navbar />
  <HeroSection />
  <PromotionsSection promotions={promotions} />
  <CatalogSection products={products} />
  <SiteFooter />
</BaseLayout>
