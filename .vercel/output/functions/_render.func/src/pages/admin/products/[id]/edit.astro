---
import BaseLayout from '../../../../components/layout/BaseLayout.astro';
import Navbar from '../../../../components/sections/Navbar.astro';
import SiteFooter from '../../../../components/sections/SiteFooter.astro';
import ProductEditorForm from '../../../../components/admin/ProductEditorForm.astro';
import { getAuthenticatedAdmin } from '../../../../lib/adminSession';
import { getProductById } from '../../../../lib/cms';

const auth = await getAuthenticatedAdmin(Astro.cookies);

if (!auth) {
  return Astro.redirect('/admin?error=unauthorized');
}

const productId = Astro.params.id;
const product = productId ? await getProductById(productId) : null;

if (!product) {
  throw new Response('Producto no encontrado', { status: 404 });
}
---

<BaseLayout title={`Editar ${product.name} | NAVI URBAN Admin`} description="Editar producto en CMS de NAVI URBAN.">
  <Navbar />
  <main class="wrapper admin-page">
    <ProductEditorForm
      product={product}
      title={`Editar ${product.name}`}
      subtitle="Productos"
      submitLabel="Guardar cambios"
      cancelHref="/admin?view=products"
    />
  </main>
  <SiteFooter />

  <style>
    .admin-page {
      padding: 2rem 0 3rem;
    }
  </style>
</BaseLayout>
