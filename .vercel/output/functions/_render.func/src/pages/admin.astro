---
import BaseLayout from '../components/layout/BaseLayout.astro';
import Navbar from '../components/sections/Navbar.astro';
import SiteFooter from '../components/sections/SiteFooter.astro';
import { getProductImageUrl } from '../lib/catalog';
import { getAuthenticatedAdmin } from '../lib/adminSession';
import { getAllProducts, getPromotions } from '../lib/cms';

const auth = await getAuthenticatedAdmin(Astro.cookies);
const loginError = Astro.url.searchParams.get('error');
const viewParam = Astro.url.searchParams.get('view');
const activeView = viewParam === 'promotions' ? 'promotions' : 'products';

const [products, promotions] = auth ? await Promise.all([getAllProducts(), getPromotions()]) : [[], []];
---

<BaseLayout title="NAVI URBAN Admin" description="Panel de administracion para productos y promociones de NAVI URBAN.">
  <Navbar />

  <main class="wrapper admin-page">
    {auth ? (
      <section class="admin-shell reveal">
        <header class="admin-header">
          <div>
            <p class="eyebrow">CMS privado</p>
            <h1>Panel principal</h1>
            <p>Visualiza un listado a la vez y entra a paginas separadas para crear o editar.</p>
          </div>
          <form method="post" action="/api/admin/logout">
            <button class="btn btn-ghost" type="submit">Cerrar sesion</button>
          </form>
        </header>

        <section class="switch-bar">
          <a class={`switch-btn ${activeView === 'products' ? 'active' : ''}`} href="/admin?view=products">
            Productos ({products.length})
          </a>
          <a class={`switch-btn ${activeView === 'promotions' ? 'active' : ''}`} href="/admin?view=promotions">
            Promociones ({promotions.length})
          </a>
        </section>

        {activeView === 'products' ? (
          <section class="list-card">
            <div class="list-head">
              <div>
                <p class="eyebrow">Productos</p>
                <h2>Listado de productos</h2>
              </div>
              <a class="btn btn-main" href="/admin/products/new">Crear nuevo producto</a>
            </div>

            <label class="filter-label">
              Buscar producto
              <input id="productSearch" placeholder="Buscar por nombre o categoria" />
            </label>

            <div class="table-wrapper">
              <table id="productsTable" class="products-table">
                <thead>
                  <tr>
                    <th>Producto</th>
                    <th>Categoria</th>
                    <th>Precio</th>
                    <th>Estado</th>
                    <th>Acciones</th>
                  </tr>
                </thead>
                <tbody>
                  {products.map((product) => (
                    <tr>
                      <td>
                        <div class="product-cell">
                          <img src={getProductImageUrl(product.images[0])} alt={product.name} />
                          <div>
                            <strong>{product.name}</strong>
                            <small>{product.tag}</small>
                          </div>
                        </div>
                      </td>
                      <td>{product.category}</td>
                      <td>${product.price} MXN</td>
                      <td>
                        <span class={`status-pill ${product.visible ? 'ok' : 'off'}`}>{product.visible ? 'Visible' : 'Oculto'}</span>
                      </td>
                      <td>
                        <div class="record-actions">
                          <a class="btn btn-ghost" href={`/admin/products/${product.id}/edit`}>Editar</a>
                          <button class="btn btn-ghost danger" type="button" data-delete-product={product.id}>Eliminar</button>
                        </div>
                      </td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          </section>
        ) : (
          <section class="list-card">
            <div class="list-head">
              <div>
                <p class="eyebrow">Promociones</p>
                <h2>Listado de promociones</h2>
              </div>
              <a class="btn btn-main" href="/admin/promotions/new">Crear nueva promocion</a>
            </div>

            <div class="promotions-list">
              {promotions.map((promotion) => (
                <article class="promotion-item">
                  <div>
                    <strong>{promotion.title}</strong>
                    <p>{promotion.description}</p>
                    <small>{promotion.redirect}</small>
                  </div>
                  <div class="record-actions">
                    <a class="btn btn-ghost" href={`/admin/promotions/${promotion.id}/edit`}>Editar</a>
                    <button class="btn btn-ghost danger" type="button" data-delete-promotion={promotion.id}>Eliminar</button>
                  </div>
                </article>
              ))}
            </div>
          </section>
        )}
      </section>
    ) : (
      <section class="login-shell reveal">
        <div class="login-card">
          <p class="eyebrow">Acceso privado</p>
          <h1>Admin CMS</h1>
          <p>Ingresa con tu usuario y contrasena para administrar productos y promociones.</p>

          {loginError ? <p class="error-box">Credenciales invalidas o sesion no valida.</p> : null}

          <form method="post" action="/api/admin/login" class="login-form">
            <label>
              Usuario
              <input name="username" autocomplete="username" required />
            </label>
            <label>
              Contrasena
              <input name="password" type="password" autocomplete="current-password" required />
            </label>
            <button class="btn btn-main" type="submit">Entrar</button>
          </form>
        </div>
      </section>
    )}
  </main>

  <SiteFooter />

  <script>
    const productSearch = document.getElementById('productSearch');
    const productsTable = document.getElementById('productsTable');
    const deleteButtonsProduct = Array.from(document.querySelectorAll('[data-delete-product]'));
    const deleteButtonsPromotion = Array.from(document.querySelectorAll('[data-delete-promotion]'));

    const setButtonLoading = (button, loadingLabel) => {
      if (!(button instanceof HTMLButtonElement)) return;
      const defaultLabel = button.dataset.defaultLabel || button.textContent || '';

      if (!button.dataset.defaultLabel) {
        button.dataset.defaultLabel = defaultLabel;
      }

      button.disabled = true;
      button.setAttribute('aria-busy', 'true');
      button.textContent = loadingLabel;
    };

    document.querySelectorAll('form').forEach((form) => {
      form.addEventListener('submit', (event) => {
        const targetForm = event.currentTarget;
        if (!(targetForm instanceof HTMLFormElement)) return;

        const submitButton = targetForm.querySelector('button[type="submit"]');
        if (!(submitButton instanceof HTMLButtonElement)) return;

        const isLogout = targetForm.action.includes('/api/admin/logout');
        const isLogin = targetForm.action.includes('/api/admin/login');

        if (isLogout) {
          setButtonLoading(submitButton, 'Cerrando...');
          return;
        }

        if (isLogin) {
          setButtonLoading(submitButton, 'Entrando...');
          return;
        }

        setButtonLoading(submitButton, 'Guardando...');
      });
    });

    productSearch?.addEventListener('input', () => {
      const query = String(productSearch.value || '').toLowerCase().trim();
      const rows = Array.from(productsTable?.querySelectorAll('tbody tr') || []);

      rows.forEach((row) => {
        const source = String(row.textContent || '').toLowerCase();
        row.style.display = source.includes(query) ? '' : 'none';
      });
    });

    deleteButtonsProduct.forEach((button) => {
      button.addEventListener('click', async () => {
        const id = button.getAttribute('data-delete-product');
        if (!id || !confirm('Eliminar este producto?')) return;

        setButtonLoading(button, 'Eliminando...');

        const response = await fetch('/api/admin/products', {
          method: 'DELETE',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ id })
        });

        if (!response.ok) {
          button.disabled = false;
          button.setAttribute('aria-busy', 'false');
          button.textContent = button.dataset.defaultLabel || 'Eliminar';
          alert('No se pudo eliminar el producto');
          return;
        }

        window.location.reload();
      });
    });

    deleteButtonsPromotion.forEach((button) => {
      button.addEventListener('click', async () => {
        const id = button.getAttribute('data-delete-promotion');
        if (!id || !confirm('Eliminar esta promocion?')) return;

        setButtonLoading(button, 'Eliminando...');

        const response = await fetch('/api/admin/promotions', {
          method: 'DELETE',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ id })
        });

        if (!response.ok) {
          button.disabled = false;
          button.setAttribute('aria-busy', 'false');
          button.textContent = button.dataset.defaultLabel || 'Eliminar';
          alert('No se pudo eliminar la promocion');
          return;
        }

        window.location.reload();
      });
    });
  </script>

  <style>
    .admin-page,
    .login-shell {
      padding: 2rem 0 3rem;
    }

    .admin-shell,
    .login-card,
    .list-card {
      background: var(--card);
      border: 1px solid var(--line);
      border-radius: 18px;
      box-shadow: 0 18px 40px rgba(17, 17, 17, 0.08);
      padding: 1rem;
    }

    .admin-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 1rem;
      margin-bottom: 1rem;
    }

    .eyebrow {
      margin: 0 0 0.35rem;
      text-transform: uppercase;
      letter-spacing: 0.12em;
      font-size: 0.75rem;
      color: var(--brand);
      font-weight: 800;
    }

    .admin-header h1,
    .login-card h1,
    .list-head h2 {
      margin: 0;
    }

    .admin-header p,
    .login-card p {
      margin: 0.45rem 0 0;
      color: var(--muted);
    }

    .switch-bar {
      display: flex;
      gap: 0.5rem;
      margin-bottom: 1rem;
      flex-wrap: wrap;
    }

    .switch-btn {
      border: 1px solid var(--line);
      border-radius: 999px;
      padding: 0.48rem 0.85rem;
      font-weight: 700;
      background: #fff;
    }

    .switch-btn.active {
      background: #111;
      color: #fff;
      border-color: #111;
    }

    .list-head {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 1rem;
      margin-bottom: 1rem;
    }

    .filter-label {
      display: grid;
      gap: 0.45rem;
      font-weight: 700;
      margin-bottom: 0.8rem;
    }

    .filter-label input,
    .login-form input {
      width: 100%;
      font: inherit;
      border: 1px solid #cdc6b8;
      background: #fff;
      border-radius: 10px;
      padding: 0.65rem 0.75rem;
    }

    .table-wrapper {
      border: 1px solid var(--line);
      border-radius: 14px;
      overflow: auto;
      background: #fff;
    }

    .products-table {
      width: 100%;
      border-collapse: collapse;
      min-width: 760px;
    }

    .products-table th,
    .products-table td {
      text-align: left;
      padding: 0.75rem;
      border-bottom: 1px solid #ece7dc;
      vertical-align: middle;
    }

    .products-table th {
      background: #f7f2e8;
      font-size: 0.83rem;
      text-transform: uppercase;
      letter-spacing: 0.04em;
    }

    .product-cell {
      display: flex;
      gap: 0.65rem;
      align-items: center;
    }

    .product-cell img {
      width: 56px;
      height: 56px;
      object-fit: cover;
      border-radius: 10px;
      border: 1px solid var(--line);
    }

    .product-cell small {
      display: block;
      color: var(--muted);
      margin-top: 0.2rem;
    }

    .status-pill {
      display: inline-flex;
      padding: 0.22rem 0.5rem;
      border-radius: 999px;
      font-size: 0.77rem;
      font-weight: 700;
      border: 1px solid transparent;
    }

    .status-pill.ok {
      background: color-mix(in srgb, var(--ok) 10%, #fff);
      color: var(--ok);
      border-color: color-mix(in srgb, var(--ok) 30%, #fff);
    }

    .status-pill.off {
      background: #f4f0e7;
      color: #7a766e;
      border-color: #d4cdc0;
    }

    .record-actions {
      display: flex;
      gap: 0.5rem;
      flex-wrap: wrap;
    }

    .promotions-list {
      display: grid;
      gap: 0.75rem;
    }

    .promotion-item {
      border: 1px solid var(--line);
      border-radius: 12px;
      background: var(--bg-soft);
      padding: 0.75rem;
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      gap: 0.75rem;
    }

    .promotion-item p,
    .promotion-item small {
      margin: 0.3rem 0 0;
      color: var(--muted);
      display: block;
    }

    .danger {
      border-color: #efc4c4;
      color: #b34848;
    }

    .login-form {
      display: grid;
      gap: 0.85rem;
      margin-top: 1rem;
    }

    .login-form label {
      display: grid;
      gap: 0.45rem;
      font-weight: 700;
    }

    .error-box {
      padding: 0.75rem 0.9rem;
      border-radius: 12px;
      background: #fff1f1;
      color: #b34848;
      border: 1px solid #efc4c4;
      margin-top: 1rem;
    }

    @media (max-width: 900px) {
      .admin-header,
      .list-head,
      .promotion-item {
        flex-direction: column;
        align-items: flex-start;
      }
    }
  </style>
</BaseLayout>
