{
	"version": 3,
	"routes": [
		{
			"handle": "filesystem"
		},
		{
			"src": "^/_astro/(.*)$",
			"headers": {
				"cache-control": "public, max-age=31536000, immutable"
			},
			"continue": true
		},
		{
			"src": "^/_server-islands/([^/]+?)/?$",
			"dest": "_render"
		},
		{
			"src": "^/_image/?$",
			"dest": "_render"
		},
		{
			"src": "^/admin/products/new/?$",
			"dest": "_render"
		},
		{
			"src": "^/admin/products/([^/]+?)/edit/?$",
			"dest": "_render"
		},
		{
			"src": "^/admin/promotions/new/?$",
			"dest": "_render"
		},
		{
			"src": "^/admin/promotions/([^/]+?)/edit/?$",
			"dest": "_render"
		},
		{
			"src": "^/admin/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/admin/login/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/admin/logout/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/admin/products/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/admin/promotions/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/admin/upload-image/?$",
			"dest": "_render"
		},
		{
			"src": "^/productos/([^/]+?)/?$",
			"dest": "_render"
		},
		{
			"src": "^/$",
			"dest": "_render"
		},
		{
			"src": "^/404/?$",
			"dest": "_render"
		},
		{
			"src": "^/.*$",
			"dest": "_render",
			"status": 404
		}
	]
}